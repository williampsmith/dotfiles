# Work / blockchain toolchains. Sourced from ~/.zshrc.
# Tracked in the dotfiles repo (real values, per your request).

# Work GitHub org slug. Enables the Claude Code SessionStart warning when you
# start a session inside a repo NOT owned by this org — i.e. you're using the
# work Claude profile on a non-work project and probably want `pcld` instead.
# See claude/hooks/work-org-warning.sh. Leave empty to disable.
#
# NOTE: the warning reads WORK_ORG from claude/settings.json `env` (so it works
# with `install.sh --claude-only`, which doesn't sync dotfiles). Keep this value
# in sync with that one. This shell export is for general/shell use.
export WORK_ORG="SubzeroLabs"

# Solana
export PATH="$HOME/.local/share/solana/install/active_release/bin:$PATH"

# WASI SDK (Rialo wasm builds)
export WASI_SDK_PATH="/opt/wasi-sdk-25"
export WASI_SYSROOT="${WASI_SDK_PATH}/share/wasi-sysroot"

# Rialo (managed by the rialoman installer)
export PATH="$HOME/.local/share/rialo/bin:$PATH"
