[pull]
	rebase = true
[rerere]
	enabled = true
[merge]
	conflictStyle = diff3
[alias]
	st = status
	ll = log --oneline
	last = log -1 HEAD --stat
	cm = commit -m
	dv = difftool -t vimdiff -y
	conf = config --global -l
	co = checkout
[user]
	name = William Smith
	email = williamprincesmith@gmail.com
[core]
	pager = delta
[delta]
	side-by-side = true
[credential]
	helper =
	helper = /usr/local/share/gcm-core/git-credential-manager
[credential "https://dev.azure.com"]
	useHttpPath = true
